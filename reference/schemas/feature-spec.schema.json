{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "SaveADay FeatureSpec",
    "description": "Specification for a feature to add to an existing SaveADay app",
    "type": "object",
    "required": [
        "apiVersion",
        "kind",
        "status",
        "target",
        "feature",
        "pages",
        "model"
    ],
    "properties": {
        "apiVersion": {
            "type": "string",
            "enum": [
                "saveaday/v1"
            ]
        },
        "kind": {
            "type": "string",
            "enum": [
                "FeatureSpec"
            ]
        },
        "status": {
            "type": "string",
            "enum": [
                "draft",
                "ready",
                "in-progress",
                "validation",
                "review",
                "done"
            ]
        },
        "target": {
            "type": "object",
            "required": [
                "app"
            ],
            "properties": {
                "app": {
                    "type": "string",
                    "description": "Slug of the target app (e.g. 'invoices', 'catalogues')"
                }
            }
        },
        "feature": {
            "type": "object",
            "required": [
                "name",
                "slug",
                "description"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "slug": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$"
                },
                "description": {
                    "type": "string"
                },
                "icon": {
                    "type": "string"
                }
            }
        },
        "pages": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "route",
                    "title",
                    "type"
                ],
                "properties": {
                    "route": {
                        "type": "string",
                        "pattern": "^/"
                    },
                    "title": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "list",
                            "form",
                            "detail",
                            "custom"
                        ]
                    },
                    "dataSource": {
                        "type": "string"
                    }
                }
            }
        },
        "model": {
            "type": "object",
            "required": [
                "name",
                "collection",
                "fields"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "collection": {
                    "type": "string"
                },
                "fields": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "object",
                        "required": [
                            "type"
                        ],
                        "properties": {
                            "type": {
                                "type": "string",
                                "enum": [
                                    "string",
                                    "number",
                                    "boolean",
                                    "array",
                                    "object"
                                ]
                            },
                            "required": {
                                "type": "boolean"
                            },
                            "default": {},
                            "description": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "navigation": {
            "type": "object",
            "properties": {
                "section": {
                    "type": "string",
                    "enum": [
                        "main",
                        "settings"
                    ]
                },
                "label": {
                    "type": "string"
                },
                "icon": {
                    "type": "string"
                },
                "position": {
                    "type": "string"
                }
            }
        }
    }
}